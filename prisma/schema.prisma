generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())

  clerkId String @unique

  name String?

  email String @unique

  role UserRole @default(GUEST)

  bookings Booking[]

  reviews Review[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

enum UserRole {
  GUEST

  STAFF

  ADMIN
}

model Hotel {
  id String @id @default(cuid())

  name String

  description String

  address String

  city String

  phone String?

  rooms Room[]

  reviews Review[]

  createdAt DateTime @default(now())
}

model RoomType {
  id          String        @id @default(cuid())
  name        String
  description String
  price       Float
  capacity    Int
  images      String[]      
  rooms       Room[]
  // 🟢 NEW: Direct relational link to Type-specific perks
  amenities   TypeAmenity[] 
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt
}

model Room {
  id          String        @id @default(cuid())
  roomNumber  String
  available   Boolean       @default(true) // Online Booking Status (Visible to Guests)
  status      RoomStatus    @default(CLEAN) // Operational Status (Visible to Admin/Staff)
  hotelId     String
  roomTypeId  String

  hotel       Hotel         @relation(fields: [hotelId], references: [id])
  roomType    RoomType      @relation(fields: [roomTypeId], references: [id])
  bookings    Booking[]
}

// 🟢 NEW: Operational states for internal staff and frontline actions
enum RoomStatus {
  CLEAN               // Ready for immediate check-in
  DIRTY               // Needs housekeeping attention post checkout
  UNDER_MAINTENANCE   // Blocked due to repairs/maintenance issues
}

model Booking {
  id String @id @default(cuid())

  checkIn DateTime

  checkOut DateTime

  status BookingStatus @default(PENDING)

  userId String

  roomId String

  user User @relation(fields: [userId], references: [id])

  room Room @relation(fields: [roomId], references: [id])

  payment Payment?

  createdAt DateTime @default(now())
}

enum BookingStatus {
  PENDING

  CONFIRMED

  CHECKED_IN

  CHECKED_OUT

  CANCELLED
}

model Payment {
  id String @id @default(cuid())

  amount Float

  status PaymentStatus @default(PENDING)

  bookingId String @unique

  booking Booking @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())
}

enum PaymentStatus {
  PENDING

  SUCCESS

  FAILED

  REFUNDED
}

model Amenity {
  id        String        @id @default(cuid())
  name      String        @unique // Prevents creating duplicate text values
  icon      String?       // Optional: Stores Lucide icon string tags (e.g., "Wifi", "Tv")
  roomTypes TypeAmenity[] 
}

/// Clean intermediate cross-reference table joining RoomTypes and Amenities
model TypeAmenity {
  roomTypeId String
  amenityId  String

  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([roomTypeId, amenityId])
}

model Review {
  id String @id @default(cuid())

  rating Int

  comment String

  userId String

  hotelId String

  user User @relation(fields: [userId], references: [id])

  hotel Hotel @relation(fields: [hotelId], references: [id])

  createdAt DateTime @default(now())
}
